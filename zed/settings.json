{
  // 本文件不直接使用，作为 Zed settings.json 的 Ponytail 相关配置参考源
  // 复制以下配置块到 ~/.config/zed/settings.json 的顶层级

  // 模型配置
  "language_models": {
    "openai_compatible": {
      "Z.AI": {
        "api_url": "https://open.bigmodel.cn/api/paas/v4",
        "available_models": [
          {
            "name": "glm-5.2",
            "display_name": "GLM-5.2",
            "max_tokens": 1000000,
            "max_output_tokens": 128000,
            "max_completion_tokens": 128000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "glm-5v-turbo",
            "display_name": "GLM-5V-Turbo",
            "max_tokens": 200000,
            "max_output_tokens": 128000,
            "max_completion_tokens": 128000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          }
        ]
      }
    }
  },

  // Agent 配置
  "agent": {
    "default_model": {
      "effort": "high",
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "enable_thinking": true
    },
    "dock": "right",
    "profiles": {
      "write": {
        "name": "write",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    // tool_permissions 视具体工作目录不同，不在全局配置中集中管理
    "favorite_models": [],
    "model_parameters": []
  },

  // 界面
  "cli_default_open_behavior": "existing_window",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },

  // 面板布局
  "project_panel": { "dock": "left" },
  "outline_panel": { "dock": "left" },
  "collaboration_panel": { "dock": "left" },
  "git_panel": { "dock": "left" },

  // Agent 服务注册
  "agent_servers": {
    "codex-acp": { "type": "registry" },
    "opencode": { "type": "registry" }
  }
}
